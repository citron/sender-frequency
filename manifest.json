{
  "manifest_version": 2,
  "name": "Sender Frequency",
  "description": "Adds a custom column for Sender Frequency to the thread pane",
  "version": "3.1.3",
  "author": "The Betterbird Project, Jörg Knobloch",
  "homepage_url": "https://github.com/Betterbird/sender-frequency",
  "browser_specific_settings": {
    "gecko": {
      "id": "jorgk@sender-frequency",
      "strict_min_version": "128.0",
      "strict_max_version": "147.*"
    }
  },
  "experiment_apis": {
    "SFreq": {
      "schema": "schema.json",
      "parent": {
        "scopes": [
          "addon_parent"
        ],
        "paths": [
          ["SFreq"]
        ],
        "script": "experiments.js"
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  }
}
